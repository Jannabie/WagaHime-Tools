if(%sdDataCXY) sp_xy 50+%1,%sdDataX+%2+%4\2+%sdDataX2,%sdDataY+%3+%5\2+%sdDataY2
else sp_xy 50+%1,%sdDataX+%2+%sdDataX2,%sdDataY+%3+%sdDataY2
