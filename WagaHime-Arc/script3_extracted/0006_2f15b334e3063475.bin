else eraseBtn 52+%1
sp_l 52+%1,0:sp_c 52+%1,0,0

cal $2=$1+"0":mid $3,$$2,1,1
if($3=="") sp_d 51+%1,0:continue
sp 51+%1,"sys/mode/em"+$3+$ext,10,0:sp_cxy 51+%1,%sdDataCXY,%sdDataCXY
if(%sdDataCXY) sp_xy 51+%1,%sdDataX+%2+%4\2+%evDataX,%sdDataY+%3+%5\2+%evDataY
else sp_xy 51+%1,%sdDataX+%2+%evDataX,%sdDataY+%3+%evDataY

next
return

